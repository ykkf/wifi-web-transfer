{
  "name": "wifi-web-transfer",
  "version": "1.0.0",
  "description": "Browser-based file transfer app.",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.wifiwebtransfer.app",
    "productName": "WiFiTransfer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "api/**/*",
      "public/**/*",
      "main.js",
      "server.js",
      "package.json"
    ]
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
